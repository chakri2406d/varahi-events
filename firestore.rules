rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── User profiles ──────────────────────────────────────────────
    // A user reads/writes their own profile; admin can read/manage any.
    match /users/{userId} {
      allow read:   if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // New accounts must start as a normal user — nobody can self-register as admin.
      allow create: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.role == 'user';
      // Owner may edit their profile but MAY NOT change their own role.
      // Only an existing admin can change roles.
      allow update: if isAdmin() ||
                    (isSignedIn() && request.auth.uid == userId
                     && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // ── Bookings ───────────────────────────────────────────────────
    // Customer sees only their own; admin sees all. Customer can create
    // and update their own (needed for the payment-proof step); only
    // admin can delete.
    match /bookings/{bookingId} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      // Admin can change anything. A customer may ONLY submit payment proof on
      // their own booking — they cannot confirm it or mark it paid/verified.
      allow update: if isAdmin() ||
                    (isSignedIn()
                     && resource.data.userId == request.auth.uid
                     && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status','paymentProofUrl','transactionId',
                                    'amountPaid','paymentSubmittedAt','updatedAt',
                                    'invoiceNo','cancelledAt','cancelledBy',
                                    'cancellationReason','cancellationCharge',
                                    'pendingPayment'])
                     && (request.resource.data.status == 'payment_pending'
                         || request.resource.data.status == 'cancelled'
                         || request.resource.data.status == resource.data.status));
      allow delete: if isAdmin();
    }

    // ── Public catalog (anyone can read, only admin can write) ─────
    match /machines/{id} { allow read: if true; allow write: if isAdmin(); }
    match /events/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /gallery/{id}  { allow read: if true; allow write: if isAdmin(); }
    match /pricing/{id}  { allow read: if true; allow write: if isAdmin(); }

    // ── Expenses / P&L — admin only ────────────────────────────────
    match /expenses/{id} { allow read, write: if isAdmin(); }

    // ── Crew / operators — admin only ──────────────────────────────
    match /crew/{id} { allow read, write: if isAdmin(); }

    // ── Contact inquiries ──────────────────────────────────────────
    // Anyone (including logged-out visitors) may submit; only admin reads.
    match /inquiries/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Reviews ────────────────────────────────────────────────────
    // Public can read approved reviews. A signed-in customer may submit one
    // (forced unapproved). Only admin can approve, edit or delete.
    match /reviews/{id} {
      allow read:   if true;
      allow create: if isSignedIn() && request.resource.data.approved == false;
      allow update, delete: if isAdmin();
    }

    // ── Invoice counter ────────────────────────────────────────────
    // A customer downloading their own invoice needs to increment this,
    // so signed-in users may read/write it. It holds no private data.
    match /counters/{id} { allow read, write: if isSignedIn(); }

    // ── Notifications — signed-in users ────────────────────────────
    // Notifications — a user only sees/edits their own; admin can send any.
    match /notifications/{id} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
